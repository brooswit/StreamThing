# StreamThing configuration. Copy to `.env` and adjust.

# Port the app listens on
PORT=3000

# Where the SQLite DB and media files live (relative paths resolve from the project root)
DATA_DIR=./data

# Default per-user quotas for newly created accounts (bytes).
# 10 GiB active, 20 GiB archive by default.
DEFAULT_STORAGE_QUOTA_BYTES=10737418240
DEFAULT_ARCHIVE_QUOTA_BYTES=21474836480

# Set to "false" to disable open account creation after you've made your accounts.
ALLOW_REGISTRATION=true

# --- Post-download conversion (browser-safe H.264/AAC MP4). Smaller = higher CRF / lower height. ---
# Max output height in pixels (downscale only, never upscale). 720 keeps files compact.
CONVERT_MAX_HEIGHT=720
# H.264 quality: higher = smaller + lower quality (18 ~ visually lossless, 26 ~ compact, 30 ~ small).
CONVERT_CRF=26
# x264 preset (slower = smaller for the same quality): ultrafast … veryfast … medium … slow.
CONVERT_PRESET=medium
# AAC audio bitrate (kbps).
CONVERT_AUDIO_KBPS=128
# Minimum file size (bytes) to treat a video as a real episode/movie vs a sample (default 50 MiB).
MIN_EPISODE_BYTES=52428800
